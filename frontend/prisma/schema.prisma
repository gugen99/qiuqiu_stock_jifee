generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  openid            String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id                String    @id @default(cuid())
  name              String?
  email             String?   @unique
  emailVerified     DateTime? @map("email_verified")
  image             String?
  openid            String?   @unique
  
  // 订阅信息
  subscriptionTier  String    @default("free") @map("subscription_tier") // free, basic, premium
  subscriptionEnd   DateTime? @map("subscription_end")
  
  // 额度
  freeQuota         Int       @default(3) @map("free_quota")
  dailyUsed         Int       @default(0) @map("daily_used")
  lastUsedAt        DateTime? @map("last_used_at")

  accounts          Account[]
  sessions          Session[]
  consultations     Consultation[]
  payments          Payment[]

  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

model Consultation {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  question  String
  answer    String   @db.Text
  tier      String   @default("free")
  
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt DateTime @default(now()) @map("created_at")

  @@map("consultations")
}

model Payment {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  orderNo     String   @unique @map("order_no")
  amount      Float
  tier        String   // basic, premium
  status      String   @default("pending") // pending, paid, failed
  
  // 微信支付信息
  prepayId    String?  @map("prepay_id")
  transactionId String? @map("transaction_id")
  paidAt      DateTime? @map("paid_at")
  
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("payments")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}
